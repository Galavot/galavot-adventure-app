# Copie este arquivo para ".env" (uso local) ou configure estas variáveis
# diretamente no painel da Vercel (Project Settings > Environment Variables).

# Access Token do Mercado Pago (Seu negócio > Configurações > Credenciais)
MP_ACCESS_TOKEN=

# URL do site já publicado (ex: https://galavotadventure.vercel.app)
# usada para redirecionar o cliente de volta após o pagamento
SITE_URL=

# Banco de dados do painel administrativo (ver README seção "Painel administrativo")
# Criado em https://supabase.com > Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Senha de acesso ao painel /admin (escolha uma senha forte, só você deve saber)
ADMIN_PASSWORD=

# Chave secreta usada para assinar a sessão do painel (invente uma frase
# longa e aleatória, ex: uma sequência de letras e números sem sentido)
ADMIN_SECRET=
